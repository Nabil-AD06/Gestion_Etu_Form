# =============================================
# CONFIGURATION ENVIRONNEMENT
# =============================================
# Copier ce fichier en .env et remplir les valeurs
#   cp .env.example .env

# ─── Serveur ──────────────────────────────────
NODE_ENV=development        # development | production
PORT=3000

# ─── Base de données PostgreSQL ───────────────
DB_HOST=postgres            # nom du service Docker (ou "localhost" hors Docker)
DB_PORT=5432
DB_NAME=gestion_etudiants
DB_USER=postgres
DB_PASSWORD=postgres123

# ─── JWT ──────────────────────────────────────
# ⚠️  CHANGER ces valeurs en production !
# Générer un secret fort : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ton_secret_jwt_super_long_et_complexe_ici
JWT_EXPIRES_IN=24h          # ex : 1h | 24h | 7d

# ─── Compte Admin par défaut ──────────────────
# Créé automatiquement au premier démarrage
ADMIN_EMAIL=admin@app.com
ADMIN_PASSWORD=Admin@123456